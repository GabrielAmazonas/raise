{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/openai/gpt-4.1",
  "provider": {
    "openrouter": {}
  },
  "agent": {
    "strategist": {
      "description": "Refine PRD and RFC artifacts before implementation",
      "mode": "all",
      "model": "openrouter/anthropic/claude-3.7-sonnet",
      "temperature": 0.2
    },
    "builder": {
      "description": "Implement approved requirements with tests",
      "mode": "all",
      "model": "openrouter/openai/gpt-4.1",
      "temperature": 0.2
    },
    "quality-gate": {
      "description": "Run adversarial review for regressions and compliance",
      "mode": "all",
      "model": "openrouter/anthropic/claude-3.7-sonnet",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "policy": {
      "description": "Enforce policy-as-code checks before commits",
      "mode": "all",
      "model": "openrouter/openai/gpt-4.1",
      "temperature": 0.1
    },
    "token-estimator": {
      "description": "Extract token and cost deltas from OpenCode CLI telemetry",
      "mode": "all",
      "model": "openrouter/openai/gpt-4o-mini",
      "temperature": 0.1
    },
    "default-fallback": {
      "description": "Fallback local governance agent when specialized agents are missing",
      "mode": "all",
      "model": "openrouter/openai/gpt-4o-mini",
      "temperature": 0.1
    }
  }
}
